# Sensores: 1 = datos simulados, 0 = leer hardware real (Raspberry Pi)
ANDESGROW_FAKE_SENSORS=1

# Cultivo configurado para la parcela: palta | vid | citrico
ANDESGROW_CULTIVO=palta

# Ruta al Random Forest entrenado (.pkl). Si no existe, se usa la heurística.
ANDESGROW_MODEL_PATH=models/riego_rf.pkl

# Orígenes permitidos por CORS (coma-separados). El dev de TanStack suele ser :3000
ANDESGROW_CORS_ORIGINS=*
